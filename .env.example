# =============================================================
# Environment Configuration
# =============================================================
# Copy this to .env and fill in your keys.
# NEVER commit .env to git.
# =============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_engine
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/portfolio_engine

# --- API Keys (Layer 1 — Data Aggregation) ---
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
POLYGON_KEY=
FMP_KEY=
# Yahoo Finance — no key needed (yfinance)

# --- Reddit & X Sentiment ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=portfolio-engine/1.0

# --- LLM (Layer 2 — Research Engine) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Vector DB ---
CHROMA_PERSIST_DIR=./data/chromadb

# --- Celery / Task Queue ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel deployment URL here once it's live, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://portfolio-growth-engine.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
